{
  "providers": ["node"],
  "phases": {
    "setup": {
      "nixPkgs": [
        "nodejs_20",
        "npm"
      ]
    },
    "install": {
      "cmds": [
        "npm install --omit=dev",
        "npm install --prefix frontend"
      ]
    },
    "build": {
      "cmds": [
        "VITE_API_URL=/api npm run build --prefix frontend"
      ]
    }
  },
  "start": {
    "cmd": "node src/server.js"
  }
}
