# Base de datos PostgreSQL (Neon)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Opcional: variables individuales de Postgres (si no se usa DATABASE_URL)
PGHOST=your-neon-host.neon.tech
PGDATABASE=neondb
PGUSER=neondb_owner
PGPASSWORD=your_password
PGPORT=5432

# JWT
JWT_SECRET=tu_secreto_muy_seguro_aqui_minimo_32_chars

# Servidor
PORT=3001
NODE_ENV=production
